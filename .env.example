# PromptFix - Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL database connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/promptfix

# OpenAI API Key (get from https://platform.openai.com/api-keys)
AI_INTEGRATIONS_OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Base URL (optional — leave as default for standard OpenAI)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Server port (Hostinger typically uses 3000 or assigns one automatically)
PORT=3000

# Node environment
NODE_ENV=production
